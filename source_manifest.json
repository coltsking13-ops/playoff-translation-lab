  "stat_calculations": {
    "PTS_75": {
      "description": "Points per 75 possessions",
      "formula": "IF per_100_available THEN (PTS_per_100 * 0.75) ELSE (Points / OffPoss * 75)",
      "level": "season/series/game"
    },
    "AST_75": {
      "description": "Assists per 75 possessions",
      "formula": "IF per_100_available THEN (AST_per_100 * 0.75) ELSE (Assists / OffPoss * 75)",
      "level": "season/series/game"
    },
    "REB_75": {
      "description": "Rebounds per 75 possessions",
      "formula": "IF rebounds_and_possessions_available THEN (Rebounds / OffPoss * 75)",
      "level": "season/series/game"
    },
    "TOV_75": {
      "description": "Turnovers per 75 possessions",
      "formula": "IF per_100_available THEN (TOV_per_100 * 0.75) ELSE (Turnovers / OffPoss * 75)",
      "level": "season/series/game"
    },
    "relative_TS": {
      "description": "Relative True Shooting %",
      "formula": "playerTS - opponentAllowedTS",
      "level": "season/series"
    },
    "relative_EFG": {
      "description": "Relative Effective FG%",
      "formula": "playerEFG - opponentAllowedEFG",
      "level": "season/series"
    },
    "relative_ORTG": {
      "description": "Relative Offensive Rating",
      "formula": "playerORTG - opponentDefensiveBenchmark",
      "level": "season/series"
    },
    "relative_DRTG": {
      "description": "Relative Defensive Rating",
      "formula": "opponentOffensiveBenchmark - playerDRTG",
      "level": "season/series"
    },
    "NET": {
      "description": "Net Rating (Offensive - Defensive)",
      "formula": "ORTG - DRTG",
      "level": "season/series/game"
    }
  },
